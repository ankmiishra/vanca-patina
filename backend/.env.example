NODE_ENV=development
PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.exn8dlzy.mongodb.net/vanca_patina?retryWrites=true&w=majority

# Used for signing/verifying JWT access tokens
JWT_SECRET=your_super_secret_jwt_key

# Comma-separated list of allowed frontend origins for CORS
CLIENT_URL=http://localhost:8080,http://localhost:5173

# Cloudinary credentials (optional; if not set, backend will keep local uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email/SMTP configuration for OTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_NAME=Vanca Patina

# Razorpay payment gateway
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
